# ERPNext API
ERPNEXT_BASE_URL=https://api.hallysway.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Price list to read selling prices from (Item Price doctype)
ERPNEXT_SELLING_PRICE_LIST=Standard Selling
# Optional: a second price list used as the strike-through "compare at" price
ERPNEXT_COMPARE_PRICE_LIST=

# Public defaults
NEXT_PUBLIC_SITE_NAME="Hally's Way Concept"
NEXT_PUBLIC_CURRENCY=NGN

# JWT secret for our own light session cookies
SESSION_SECRET=change-me-to-a-long-random-string
